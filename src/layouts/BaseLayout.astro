---
// Fonts auto-hébergées (pas de CDN Google → RGPD + perf). display:swap intégré.
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono/600.css';
import '@fontsource/jetbrains-mono/700.css';
// URLs des 2 fichiers critiques pour le preload (mêmes assets hashés que le CSS).
import interLatinUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import monoLatinUrl from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-600-normal.woff2?url';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  /** Pages à exclure de l'index (404…) */
  noindex?: boolean;
  /** Schémas JSON-LD additionnels propres à la page (SoftwareApplication, BreadcrumbList…) */
  schemas?: Record<string, unknown>[];
}

const {
  // Title < 60 car. (mot-clé + bénéfice + marque) ; description < 155 car.
  title = 'Terrain constructible à La Réunion, scoré — LA BUSE',
  description = 'LA BUSE croise cadastre, PLU, PPR, prix et propriétaires sur les 24 communes de La Réunion. Repérez les terrains constructibles avant les autres.',
  noindex = false,
  schemas = [],
} = Astro.props;

const site = 'https://labuse.immo';
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = `${site}/og.png`;

// JSON-LD — présents sur toutes les pages : Organization + WebSite.
// Les schémas propres à une page (SoftwareApplication, BreadcrumbList…)
// arrivent via le prop `schemas`.
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'LA BUSE',
  url: site,
  inLanguage: 'fr',
  publisher: { '@type': 'Organization', name: 'LA BUSE', url: site },
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'LA BUSE',
  legalName: 'LA BUSE',
  url: site,
  logo: `${site}/favicon.svg`,
  description,
  slogan: 'Repérez les parcelles mutables avant les autres.',
  areaServed: {
    '@type': 'Place',
    name: 'La Réunion',
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'La Réunion',
      addressCountry: 'FR',
    },
  },
  knowsAbout: [
    'Intelligence foncière',
    'Foncier constructible',
    'Promotion immobilière',
    'Cadastre',
    'PLU',
    'PPR',
  ],
  email: 'contact@labuse.immo',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: 'contact@labuse.immo',
    availableLanguage: 'French',
  },
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Active la révélation au scroll seulement si JS est présent (évite le FOUC) -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#060a08" />
    <!-- Preload des 2 fonts critiques (h1 Inter + labels mono) : pas de FOUT sur le titre -->
    <link rel="preload" href={interLatinUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={monoLatinUrl} as="font" type="font/woff2" crossorigin />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="LA BUSE" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="LA BUSE — radar foncier de La Réunion" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </head>
  <body>
    <a href="#contenu" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-green focus:px-4 focus:py-2 focus:font-semibold focus:text-[#04140f]">
      Aller au contenu
    </a>
    <slot />

    <!-- Header compact au scroll -->
    <script is:inline>
      (() => {
        const headers = document.querySelectorAll('[data-header]');
        if (!headers.length) return;
        const onScroll = () => {
          const scrolled = window.scrollY > 12;
          headers.forEach((h) => h.toggleAttribute('data-scrolled', scrolled));
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>

    <!-- Révélation douce au scroll (respecte prefers-reduced-motion) -->
    <script is:inline>
      (() => {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const els = document.querySelectorAll('.reveal');
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
