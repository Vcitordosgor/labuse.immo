---
// Fonts auto-hébergées (pas de CDN Google → RGPD + perf). display:swap intégré.
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono/600.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'LA BUSE — Intelligence foncière pour promoteurs à La Réunion',
  description = 'LA BUSE note et cartographie tout le foncier constructible des 24 communes de La Réunion. Cadastre, PLU, PPR, faisabilité, prix et propriétaires croisés : identifiez les parcelles à bâtir — et leurs propriétaires — avant tout le monde.',
} = Astro.props;

const site = 'https://labuse.immo';
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = `${site}/og.svg`;

// JSON-LD Organization
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'LA BUSE',
  legalName: 'LA BUSE',
  url: site,
  logo: `${site}/favicon.svg`,
  description,
  slogan: 'Repérez les parcelles mutables avant les autres.',
  areaServed: {
    '@type': 'Place',
    name: 'La Réunion',
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'La Réunion',
      addressCountry: 'FR',
    },
  },
  knowsAbout: [
    'Intelligence foncière',
    'Foncier constructible',
    'Promotion immobilière',
    'Cadastre',
    'PLU',
    'PPR',
  ],
  email: 'contact@labuse.immo',
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Active la révélation au scroll seulement si JS est présent (évite le FOUC) -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#060a08" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="intelligence foncière, foncier constructible, promoteurs immobiliers, La Réunion, cadastre, PLU, PPR, prospection foncière, parcelles mutables"
    />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="LA BUSE" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="LA BUSE — radar foncier de La Réunion" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#contenu" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-green focus:px-4 focus:py-2 focus:font-semibold focus:text-[#04140f]">
      Aller au contenu
    </a>
    <slot />

    <!-- Header compact au scroll -->
    <script is:inline>
      (() => {
        const headers = document.querySelectorAll('[data-header]');
        if (!headers.length) return;
        const onScroll = () => {
          const scrolled = window.scrollY > 12;
          headers.forEach((h) => h.toggleAttribute('data-scrolled', scrolled));
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>

    <!-- Révélation douce au scroll (respecte prefers-reduced-motion) -->
    <script is:inline>
      (() => {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const els = document.querySelectorAll('.reveal');
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
