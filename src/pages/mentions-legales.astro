---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { CONTACT_EMAIL } from '../consts';

const updated = '5 juillet 2026';
---

<BaseLayout
  title="Mentions légales — LA BUSE"
  description="Mentions légales du site labuse.immo, plateforme d'intelligence foncière à La Réunion."
>
  <Header />
  <main id="contenu" class="pt-[76px]">
    <section class="mx-auto max-w-[760px] px-5 py-16 sm:px-8 sm:py-20">
      <p class="eyebrow">Informations légales</p>
      <h1 class="mt-6 text-[32px] font-semibold leading-[1.08] tracking-tightest sm:text-[42px]">
        Mentions <span class="text-green">légales.</span>
      </h1>
      <p class="mt-4 text-[14px] text-muted">Dernière mise à jour : {updated}.</p>

      <div class="mt-10 flex flex-col gap-8 text-[16px] leading-relaxed text-[#c3ceca]">
        <div>
          <h2 class="text-[20px] font-semibold text-ink">Éditeur du site</h2>
          <p class="mt-3">
            Victor Lagane — entrepreneur individuel (EI), exerçant sous le nom
            « LA&nbsp;BUSE ».<br />
            SIRET&nbsp;: 987&nbsp;641&nbsp;917&nbsp;00016<br />
            3 chemin de la Citerne, La Montagne<br />
            97417 Saint-Denis, La Réunion<br />
            Directeur de la publication&nbsp;: Victor Lagane<br />
            Contact&nbsp;: <a href={`mailto:${CONTACT_EMAIL}`} class="text-green underline decoration-green/40 underline-offset-2">{CONTACT_EMAIL}</a>
          </p>
        </div>

        <div>
          <h2 class="text-[20px] font-semibold text-ink">Hébergement</h2>
          <p class="mt-3">
            Ce site est hébergé par Cloudflare, Inc.<br />
            101 Townsend Street, San Francisco, CA 94107, États-Unis<br />
            <a href="https://www.cloudflare.com" rel="noopener" class="text-green underline decoration-green/40 underline-offset-2">www.cloudflare.com</a>
          </p>
        </div>

        <div>
          <h2 class="text-[20px] font-semibold text-ink">Propriété intellectuelle</h2>
          <p class="mt-3">
            L'ensemble des contenus de ce site (textes, visuels, marque LA BUSE, éléments
            graphiques) est protégé par le droit de la propriété intellectuelle. Toute
            reproduction ou représentation, totale ou partielle, sans autorisation écrite
            préalable est interdite.
          </p>
        </div>

        <div>
          <h2 class="text-[20px] font-semibold text-ink">Données personnelles</h2>
          <p class="mt-3">
            Le site et la plateforme LA BUSE réalisent deux traitements de données
            personnelles distincts&nbsp;: celui des visiteurs qui nous contactent, et celui
            des propriétaires fonciers dont les données publiques sont analysées par le
            produit. Les deux sont décrits dans notre
            <a href="/confidentialite" class="text-green underline decoration-green/40 underline-offset-2">politique de confidentialité</a>.
            Ce site n'utilise aucun cookie ni traceur.
          </p>
        </div>
      </div>

      <a href="/" class="mt-12 inline-flex items-center gap-2.5 text-[16px] font-medium text-ink transition-opacity hover:opacity-80">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5M11 6l-6 6 6 6"></path>
        </svg>
        Retour au site
      </a>
    </section>
  </main>
  <Footer />
</BaseLayout>
