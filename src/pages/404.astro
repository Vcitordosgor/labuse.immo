---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  noindex
  title="Page introuvable — LA BUSE"
  description="Cette page n’existe pas. Retournez au radar foncier de La Réunion."
>
  <Header />
  <main id="contenu" class="pt-[76px]">
    <section class="mx-auto flex max-w-content flex-col items-center px-5 py-24 text-center sm:px-8 sm:py-32">
      <div
        class="inline-flex items-center rounded-full border border-green/40 bg-green/5 px-4 py-2 font-mono text-[13px] font-semibold uppercase tracking-[.14em] text-green-soft"
      >
        Signal perdu
      </div>
      <h1 class="mt-8 text-[56px] font-bold leading-none tracking-tightest text-green sm:text-[88px]">404</h1>
      <p class="mt-6 max-w-[440px] text-[18px] leading-relaxed text-[#aab5b0] sm:text-[20px]">
        Cette page n’apparaît sur aucun de nos radars. La parcelle que vous cherchez
        est peut-être ailleurs.
      </p>
      <a
        href="/"
        class="mt-10 inline-flex h-[54px] items-center gap-3 rounded-2xl bg-green px-7 text-[17px] font-semibold text-[#04140f] shadow-glow transition-transform hover:-translate-y-0.5"
      >
        Revenir au radar
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </section>
  </main>
  <Footer />
</BaseLayout>
