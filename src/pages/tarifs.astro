---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Reveal from '../components/Reveal.astro';
import { CONTACT_ANCHOR } from '../consts';

// ─────────────────────────────────────────────────────────────────────────────
//  ⚠️ [VIC] CHIFFRES À RENSEIGNER — exacts, tirés de la base LABUSE, jamais
//  arrondis vers le haut. Tant que ces tokens ⟨…⟩ sont visibles, NE PAS merger.
// ─────────────────────────────────────────────────────────────────────────────
const DATA = {
  nbCommunes: '⟨NB_COMMUNES⟩', //   ex : "23 communes calibrées"
  nbParcelles: '⟨NB_PARCELLES⟩', // ex : "412 300" — chiffre réel de la base
  // 2-3 chiffres de preuve vérifiables (valeur + libellé côté acheteur)
  preuve: [
    { valeur: '⟨CHIFFRE 1⟩', label: '⟨ex : règles PLU tracées⟩' },
    { valeur: '⟨CHIFFRE 2⟩', label: '⟨ex : communes calibrées⟩' },
    { valeur: '⟨CHIFFRE 3⟩', label: '⟨ex : erreur vue mer⟩' },
  ],
  // Décisions (défauts recommandés appliqués) :
  fondateursTotal: 8, //           recommandé : 8
  fondateursRestantes: 8, //       ⚠️ [VIC] MAJ À LA MAIN — jamais de compteur factice
  afficherFourchetteOrga: false, // recommandé : non → "sur devis" seul
};

const plans = [
  {
    id: 'inde',
    name: 'Indé',
    featured: false,
    monthly: '290',
    annual: '2 900',
    pour: 'Marchand de biens, CMI, géomètre — en solo',
    users: '1 utilisateur',
    features: [
      `Accès complet à la plateforme, ${DATA.nbCommunes}`,
      'Fiches parcelles sourcées — chaque valeur tracée à sa source',
      'Go/no-go argumenté : règles d’urbanisme à l’article et à la page',
    ],
    cta: 'Réserver une démo',
  },
  {
    id: 'pro',
    name: 'Pro',
    featured: true,
    monthly: '490',
    annual: '4 900',
    pour: 'Promoteurs, lotisseurs, CMI structurés',
    users: '2 utilisateurs inclus',
    extraSeat: 'Siège supplémentaire : 150 €/mois',
    features: [
      'Tout ce que contient l’offre Indé',
      'Comptes équipe',
      'Partage des dossiers entre collaborateurs',
    ],
    cta: 'Réserver une démo',
  },
  {
    id: 'orga',
    name: 'Organisation',
    featured: false,
    devis: true,
    pour: 'Bailleurs sociaux, grands comptes, EnR',
    users: 'Utilisateurs selon besoin',
    features: [
      'Tout ce que contient l’offre Pro',
      'Déploiement dédié',
      'Accompagnement à la prise en main',
    ],
    cta: 'Nous contacter',
  },
];
---

<BaseLayout
  title="Tarifs — LA BUSE · Intelligence foncière à La Réunion, à partir de 290 €/mois"
  description="Les tarifs de LA BUSE : Indé 290 €/mois, Pro 490 €/mois, Organisation sur devis. La donnée foncière qui raisonne — go/no-go sourcé, règles d’urbanisme tracées à l’article. Réservez une démo."
>
  <Header />
  <main id="contenu" class="pt-[76px]">
    <!-- ── En-tête ── -->
    <section class="mx-auto max-w-content px-5 pt-16 sm:px-8 sm:pt-20">
      <Reveal class="max-w-[760px]">
        <p class="eyebrow">Tarifs</p>
        <h1 class="mt-6 text-[34px] font-semibold leading-[1.06] tracking-tightest sm:text-[52px]">
          La donnée qui raisonne, <span class="text-green">pas celle qui décore.</span>
        </h1>
        <p class="mt-6 max-w-[620px] text-[17px] leading-relaxed text-[#aab5b0] sm:text-[20px]">
          Chaque parcelle notée, chaque règle d’urbanisme tracée à l’article et à la page.
          Sécurisez vos go/no-go, évitez le mauvais foncier et trouvez le bon avant les
          autres — à La Réunion, c’est natif. À partir de
          <span class="font-semibold text-ink">290 €/mois</span>.
        </p>
      </Reveal>

      <!-- ── Toggle période ── -->
      <Reveal delay={80} class="mt-10">
        <div
          class="inline-flex items-center gap-1 rounded-full border border-white/[.08] bg-surface/70 p-1"
          role="group"
          aria-label="Période de facturation"
          data-toggle
        >
          <button type="button" data-period-btn="mensuel" aria-pressed="false"
            class="rounded-full px-4 py-2 text-[14px] font-medium text-muted transition-colors">
            Mensuel
          </button>
          <button type="button" data-period-btn="annuel" aria-pressed="true"
            class="rounded-full px-4 py-2 text-[14px] font-medium text-muted transition-colors">
            Annuel
            <span class="ml-1.5 rounded-full bg-green/15 px-2 py-0.5 text-[11px] font-semibold text-green">2 mois offerts</span>
          </button>
        </div>
      </Reveal>
    </section>

    <!-- ── Grille ── -->
    <section class="mx-auto max-w-content px-5 pb-4 pt-8 sm:px-8">
      <div id="tarifs-grid" data-period="annuel" class="grid gap-5 lg:grid-cols-3 lg:items-start">
        {
          plans.map((plan, i) => (
            <Reveal delay={i * 90}>
              <article
                class:list={[
                  'relative flex h-full flex-col rounded-3xl border p-7',
                  plan.featured
                    ? 'border-green/45 bg-gradient-to-b from-[#0f221b] to-[#0a1310] shadow-[0_24px_70px_-30px_rgba(47,224,160,.5)] lg:-mt-3 lg:pb-9'
                    : 'border-white/[.08] bg-gradient-to-b from-[#0e1a16] to-[#0a1310]',
                ]}
              >
                {plan.featured && (
                  <span class="absolute -top-3 left-7 inline-flex items-center gap-1.5 rounded-full bg-green px-3 py-1 text-[12px] font-semibold text-[#04140f]">
                    ★ Le plus choisi
                  </span>
                )}

                <h2 class="text-[15px] font-mono font-semibold uppercase tracking-[.16em] text-green-soft">
                  {plan.name}
                </h2>

                {/* Prix — piloté par le toggle */}
                <div class="mt-4 min-h-[64px]">
                  {plan.devis ? (
                    <div>
                      <span class="text-[38px] font-bold leading-none tracking-tight text-ink">Sur devis</span>
                      <p class="mt-2 text-[14px] text-muted">Tarification adaptée à votre périmètre.</p>
                    </div>
                  ) : (
                    <div>
                      <div data-when="mensuel">
                        <span class="text-[42px] font-bold leading-none tracking-tight text-ink">{plan.monthly} €</span>
                        <span class="text-[16px] text-muted"> /mois</span>
                      </div>
                      <div data-when="annuel">
                        <span class="text-[42px] font-bold leading-none tracking-tight text-ink">{plan.annual} €</span>
                        <span class="text-[16px] text-muted"> /an</span>
                        <p class="mt-1.5 text-[13px] text-green">2 mois offerts · engagement annuel</p>
                      </div>
                    </div>
                  )}
                </div>

                <p class="mt-4 text-[14px] leading-snug text-[#a7b2ac]">{plan.pour}</p>

                <div class="my-5 h-px bg-white/[.07]" />

                <p class="text-[14px] font-semibold text-ink">{plan.users}</p>
                {plan.extraSeat && (
                  <p class="mt-1 text-[13px] text-muted">{plan.extraSeat}</p>
                )}

                <ul class="mt-4 flex flex-1 flex-col gap-3">
                  {plan.features.map((f) => (
                    <li class="flex items-start gap-2.5 text-[14.5px] leading-snug text-[#c3ceca]">
                      <span class="mt-0.5 grid h-4 w-4 flex-none place-items-center rounded-full bg-green/12 text-green" aria-hidden="true">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                      </span>
                      {f}
                    </li>
                  ))}
                </ul>

                <a
                  href={CONTACT_ANCHOR}
                  class:list={[
                    'mt-7 inline-flex h-[52px] items-center justify-center gap-2.5 rounded-xl px-6 text-[15px] font-semibold transition-all',
                    plan.featured
                      ? 'bg-green text-[#04140f] shadow-glow hover:-translate-y-0.5'
                      : 'border border-coast/25 text-ink hover:border-green/60 hover:bg-green/5',
                  ]}
                >
                  {plan.cta}
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </article>
            </Reveal>
          ))
        }
      </div>
      <p class="mt-6 text-center text-[13px] text-muted">
        Prix HT. Sans paiement en ligne : chaque offre démarre par une démonstration sur votre commune cible.
      </p>
    </section>

    <!-- ── Offre fondateurs ── -->
    <section class="mx-auto max-w-content px-5 py-16 sm:px-8 sm:py-20">
      <Reveal>
        <div class="overflow-hidden rounded-3xl border border-green/25 bg-gradient-to-b from-[#0f221b] to-[#0a1310] p-7 sm:p-10">
          <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-[560px]">
              <p class="eyebrow">Offre fondateurs — {DATA.fondateursTotal} places</p>
              <h2 class="mt-5 text-[26px] font-semibold leading-[1.12] tracking-tightest sm:text-[34px]">
                <span class="text-green">−50 %</span> pendant 12 mois.
              </h2>
              <p class="mt-5 text-[16px] leading-relaxed text-[#c3ceca]">
                Sur l’offre Indé ou Pro, souscrite maintenant : la première année à moitié
                prix — soit <span class="font-semibold text-ink">145 €/mois</span> sur Indé,
                <span class="font-semibold text-ink"> 245 €/mois</span> sur Pro. Ensuite, votre
                tarif reste garanti au prix affiché à la souscription.
              </p>
              <p class="mt-4 text-[15px] text-muted">
                En contrepartie : quelques sessions de feedback produit, et l’autorisation
                d’utiliser votre témoignage et votre logo.
              </p>
            </div>
            <div class="flex-none rounded-2xl border border-white/[.08] bg-bg/50 px-7 py-6 text-center">
              <div class="text-[40px] font-bold leading-none text-green">{DATA.fondateursRestantes}</div>
              <div class="mt-2 text-[13px] text-muted">places restantes sur {DATA.fondateursTotal}</div>
              <a href={CONTACT_ANCHOR} class="mt-5 inline-flex h-[48px] items-center justify-center gap-2 rounded-xl bg-green px-6 text-[15px] font-semibold text-[#04140f] shadow-glow transition-transform hover:-translate-y-0.5">
                Réserver ma place
              </a>
            </div>
          </div>
          <p class="mt-6 text-[12px] text-muted">
            Offre limitée et datée. Ce n’est pas un tarif : les prix de la grille ne changent pas.
          </p>
        </div>
      </Reveal>
    </section>

    <!-- ── Chiffres de preuve ── -->
    <section class="border-y border-white/5 bg-surface/30">
      <div class="mx-auto max-w-content px-5 py-14 sm:px-8 sm:py-16">
        <Reveal class="max-w-[720px]">
          <p class="eyebrow">La preuve, pas la promesse</p>
          <h2 class="mt-5 text-[24px] font-semibold leading-[1.12] tracking-tightest sm:text-[32px]">
            Chaque valeur, <span class="text-green">tracée à sa source.</span>
          </h2>
        </Reveal>
        <dl class="mt-10 grid grid-cols-2 gap-x-6 gap-y-8 lg:grid-cols-4">
          <Reveal as="div" class="flex flex-col border-l border-green/25 pl-5">
            <dt class="order-2 mt-2 text-[14px] text-muted">parcelles couvertes</dt>
            <dd class="order-1 text-[32px] font-bold leading-none tracking-tight text-green sm:text-[42px]">{DATA.nbParcelles}</dd>
          </Reveal>
          <Reveal as="div" delay={70} class="flex flex-col border-l border-green/25 pl-5">
            <dt class="order-2 mt-2 text-[14px] text-muted">communes</dt>
            <dd class="order-1 text-[32px] font-bold leading-none tracking-tight text-green sm:text-[42px]">{DATA.nbCommunes}</dd>
          </Reveal>
          {
            DATA.preuve.slice(0, 2).map((p, i) => (
              <Reveal as="div" delay={140 + i * 70} class="flex flex-col border-l border-green/25 pl-5">
                <dt class="order-2 mt-2 text-[14px] text-muted">{p.label}</dt>
                <dd class="order-1 text-[32px] font-bold leading-none tracking-tight text-green sm:text-[42px]">{p.valeur}</dd>
              </Reveal>
            ))
          }
        </dl>
        <p class="mt-8 text-[13px] text-muted">
          Chiffres exacts au jour de la mise en ligne, issus de la base LA BUSE.
        </p>
      </div>
    </section>

    <!-- ── CTA final ── -->
    <section class="mx-auto max-w-content px-5 py-16 sm:px-8 sm:py-20">
      <Reveal class="text-center">
        <h2 class="mx-auto max-w-[640px] text-[28px] font-semibold leading-[1.1] tracking-tightest sm:text-[40px]">
          Prêt à sécuriser vos <span class="text-green">go/no-go</span> ?
        </h2>
        <p class="mx-auto mt-5 max-w-[520px] text-[17px] leading-relaxed text-[#aab5b0]">
          On vous montre LA BUSE en conditions réelles, sur votre commune cible. Sans engagement.
        </p>
        <a href={CONTACT_ANCHOR} class="mt-8 inline-flex h-[56px] items-center gap-3 rounded-2xl bg-green px-8 text-[17px] font-semibold text-[#04140f] shadow-glow transition-transform hover:-translate-y-0.5">
          Réserver une démo
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </Reveal>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Toggle période : affiche mensuel OU annuel selon data-period sur la grille */
  #tarifs-grid[data-period='annuel'] [data-when='mensuel'] { display: none; }
  #tarifs-grid[data-period='mensuel'] [data-when='annuel'] { display: none; }
  [data-toggle] button[aria-pressed='true'] {
    background: var(--green);
    color: #04140f;
  }
  [data-toggle] button[aria-pressed='true'] span { display: none; }
</style>

<script is:inline>
  (() => {
    const grid = document.getElementById('tarifs-grid');
    const btns = document.querySelectorAll('[data-period-btn]');
    if (!grid || !btns.length) return;
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const period = btn.getAttribute('data-period-btn');
        grid.setAttribute('data-period', period);
        btns.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
      });
    });
  })();
</script>
