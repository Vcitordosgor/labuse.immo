---
import Reveal from './Reveal.astro';

const pains = [
  'Une dizaine de portails à recouper à la main : Géoportail, cadastre, PLU, PPR, SAR…',
  'Des règlements de zone en PDF, illisibles à l’échelle d’un territoire entier.',
  'Du repérage terrain chronophage pour vérifier façades, accès et voisinage.',
  'Des gisements dormants qui restent invisibles — et partent chez un concurrent.',
];
---

<section class="border-t border-white/5">
  <div class="mx-auto max-w-content px-5 py-20 sm:px-8 sm:py-24">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)] lg:items-center lg:gap-20">
      <Reveal>
        <p class="eyebrow">Le constat</p>
        <h2 class="mt-6 max-w-[620px] text-[30px] font-semibold leading-[1.08] tracking-tightest sm:text-[42px]">
          Prospecter le foncier ici, c’est recouper dix sources <span class="text-green">à la main.</span>
        </h2>
        <p class="mt-7 max-w-[560px] text-[17px] leading-relaxed text-[#aab5b0] sm:text-[19px]">
          L’information existe — mais elle est éclatée entre des portails, des PDF de
          règlement et des heures de terrain. Résultat : des semaines pour qualifier une
          commune, des opportunités qui filent, et du foncier constructible qui reste
          sous les radars.
        </p>
        <p class="mt-5 max-w-[560px] text-[17px] leading-relaxed text-[#aab5b0] sm:text-[19px]">
          LA BUSE fait ce recoupement à votre place, et fait remonter ce qui est
          <span class="font-medium text-ink"> réellement exploitable</span>. Le trésor
          foncier est là, sous vos pieds : on vous donne la carte.
        </p>
      </Reveal>

      <Reveal delay={120}>
        <ul class="flex flex-col gap-3">
          {
            pains.map((pain) => (
              <li class="card flex items-start gap-4 px-5 py-4">
                <span class="mt-1 h-1.5 w-1.5 flex-none rounded-full bg-green shadow-[0_0_10px_rgba(47,224,160,.7)]" aria-hidden="true" />
                <span class="text-[15.5px] leading-snug text-[#c3ceca]">{pain}</span>
              </li>
            ))
          }
        </ul>
      </Reveal>
    </div>
  </div>
</section>
