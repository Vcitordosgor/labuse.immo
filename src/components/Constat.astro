---
import Reveal from './Reveal.astro';

const pains = [
  'Cadastre, PLU, PPR, SAR, prix, propriétaires : dix sources à recouper à la main.',
  'Des règlements de zone en PDF, illisibles à l’échelle d’une commune entière.',
  'Des heures de terrain pour vérifier façade, accès, voisinage et division possible.',
  'Impossible de savoir vite qui possède quoi — ni comment le joindre.',
];
---

<section class="border-t border-white/5">
  <div class="mx-auto max-w-content px-5 py-20 sm:px-8 sm:py-24">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)] lg:items-center lg:gap-20">
      <Reveal>
        <p class="eyebrow">Le constat</p>
        <h2 class="mt-6 max-w-[620px] text-[30px] font-semibold leading-[1.08] tracking-tightest sm:text-[42px]">
          Le foncier constructible est là. <span class="text-green">Personne ne le voit.</span>
        </h2>
        <p class="mt-7 max-w-[560px] text-[17px] leading-relaxed text-[#aab5b0] sm:text-[19px]">
          À La Réunion, l’information foncière est éclatée : cadastre, PLU, PPR, prix,
          propriétaires… dispersés sur dix portails, des PDF de règlement et des heures
          de terrain. Qualifier une seule commune prend des semaines.
        </p>
        <p class="mt-5 max-w-[560px] text-[17px] leading-relaxed text-[#aab5b0] sm:text-[19px]">
          Pendant ce temps, les meilleures parcelles partent — souvent à celui qui a
          simplement regardé au bon endroit. LA BUSE fait le recoupement à votre place et
          révèle ce qui est <span class="font-medium text-ink">réellement exploitable</span>,
          propriétaire compris.
        </p>
      </Reveal>

      <Reveal delay={120}>
        <ul class="flex flex-col gap-3">
          {
            pains.map((pain) => (
              <li class="card flex items-start gap-4 px-5 py-4">
                <span class="mt-1 h-1.5 w-1.5 flex-none rounded-full bg-green shadow-[0_0_10px_rgba(47,224,160,.7)]" aria-hidden="true" />
                <span class="text-[15.5px] leading-snug text-[#c3ceca]">{pain}</span>
              </li>
            ))
          }
        </ul>
      </Reveal>
    </div>
  </div>
</section>
