---
import Reveal from './Reveal.astro';

const figures = [
  // TODO: confirmer le volume réel de parcelles notées dans la base LA BUSE.
  { value: '500 000+', label: 'parcelles notées' },
  { value: '24', label: 'communes couvertes' },
  { value: '22', label: 'couches croisées' },
  { value: '1 clic', label: 'pour la faisabilité' },
];
---

<section id="reunion" class="border-y border-white/5 bg-surface/30">
  <div class="mx-auto max-w-content px-5 py-16 sm:px-8 sm:py-20">
    <Reveal class="max-w-[720px]">
      <p class="eyebrow">Chiffres clés · La Réunion</p>
      <h2 class="mt-6 text-[26px] font-semibold leading-[1.12] tracking-tightest sm:text-[36px]">
        Toute l’île, <span class="text-green">déjà passée au crible.</span>
      </h2>
    </Reveal>

    <dl class="mt-12 grid grid-cols-2 gap-x-6 gap-y-10 lg:grid-cols-4">
      {
        figures.map((fig, i) => (
          <Reveal as="div" delay={i * 90} class="border-l border-green/25 pl-5">
            <dd class="text-[38px] font-bold leading-none tracking-tight text-green sm:text-[52px]">
              {fig.value}
            </dd>
            <dt class="mt-3 text-[15px] text-muted sm:text-[16px]">{fig.label}</dt>
          </Reveal>
        ))
      }
    </dl>
  </div>
</section>
