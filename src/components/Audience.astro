---
import Reveal from './Reveal.astro';

const audiences = [
  {
    title: 'Promoteurs',
    body: 'Sécurisez votre sourcing : un flux continu de parcelles constructibles qualifiées, avec leur faisabilité et leur propriétaire — avant qu’elles n’arrivent sur le marché.',
    icon: 'building',
  },
  {
    title: 'Bailleurs sociaux',
    body: 'Identifiez le foncier mobilisable pour du logement social : zones, densités, servitudes et propriétaires, sur les 24 communes, dans un seul outil.',
    icon: 'community',
  },
  {
    title: 'Marchands de biens',
    body: 'Repérez vite les biens à fort potentiel de valorisation, les divisions possibles et les situations à saisir — estimation et contact propriétaire compris.',
    icon: 'tag',
  },
  {
    title: 'Investisseurs & foncières',
    body: 'Bâtissez votre stratégie d’acquisition sur des données solides : potentiel, contraintes et prix à l’échelle de toute La Réunion.',
    icon: 'chart',
  },
];

const icons: Record<string, string> = {
  building: '<path d="M3 21h18"/><path d="M5 21V5a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v16"/><path d="M13 9h5a1 1 0 0 1 1 1v11"/><path d="M8 8h.01M8 12h.01M8 16h.01"/>',
  community: '<path d="M3 21h18"/><path d="M5 21V8l5-4 5 4v13"/><path d="M15 21V11l4 2.5V21"/><path d="M8.5 10h.01M11.5 10h.01M8.5 13.5h.01M11.5 13.5h.01M8.5 17h.01M11.5 17h.01"/>',
  tag: '<path d="M12.6 3H7a4 4 0 0 0-4 4v5.6a2 2 0 0 0 .6 1.4l7.4 7.4a2 2 0 0 0 2.8 0l5.6-5.6a2 2 0 0 0 0-2.8L14 3.6A2 2 0 0 0 12.6 3Z"/><circle cx="8.5" cy="8.5" r="1.2"/>',
  chart: '<path d="M3 3v18h18"/><path d="M7 15l4-5 3 3 5-7"/>',
};
---

<section>
  <div class="mx-auto max-w-content px-5 py-20 sm:px-8 sm:py-24">
    <Reveal class="max-w-[720px]">
      <p class="eyebrow">Pour qui</p>
      <h2 class="mt-6 text-[30px] font-semibold leading-[1.08] tracking-tightest sm:text-[42px]">
        Fait pour ceux qui <span class="text-green">construisent l’île.</span>
      </h2>
    </Reveal>

    <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        audiences.map((a, i) => (
          <Reveal delay={i * 80}>
            <article class="card card-interactive h-full p-6">
              <span class="mb-5 grid h-12 w-12 place-items-center rounded-xl border border-green/30 bg-green/5 text-green">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[a.icon]} />
              </span>
              <h3 class="text-[19px] font-semibold tracking-tight">{a.title}</h3>
              <p class="mt-2.5 text-[15px] leading-relaxed text-[#a7b2ac]">{a.body}</p>
            </article>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
