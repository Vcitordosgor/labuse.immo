---
import Reveal from './Reveal.astro';
import ContactForm from './ContactForm.tsx';

const reassurances = [
  'Une démo en conditions réelles, sur votre commune cible',
  'Sans engagement — on vous montre ce que LA BUSE révèle',
  'Réponse sous 24 h ouvrées',
];
---

<section id="contact" class="scroll-mt-24 border-t border-white/5">
  <div class="mx-auto max-w-content px-5 py-20 sm:px-8 sm:py-24">
    <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
      <Reveal>
        <p class="eyebrow">Contact</p>
        <h2 class="mt-6 text-[30px] font-semibold leading-[1.08] tracking-tightest sm:text-[42px]">
          Parlons de votre <span class="text-green">commune cible.</span>
        </h2>
        <p class="mt-6 max-w-[420px] text-[17px] leading-relaxed text-[#aab5b0] sm:text-[19px]">
          Dites-nous qui vous êtes et ce que vous cherchez. On vous montre LA BUSE en
          conditions réelles, sur le territoire qui vous intéresse.
        </p>
        <ul class="mt-8 flex flex-col gap-3.5">
          {
            reassurances.map((r) => (
              <li class="flex items-start gap-3 text-[15px] text-[#c3ceca]">
                <span class="mt-0.5 grid h-5 w-5 flex-none place-items-center rounded-full bg-green/10 text-green" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
                {r}
              </li>
            ))
          }
        </ul>
      </Reveal>

      <Reveal delay={120} class="card p-6 sm:p-8">
        <ContactForm client:visible />
      </Reveal>
    </div>
  </div>
</section>
