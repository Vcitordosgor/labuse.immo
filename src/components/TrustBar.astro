---
import Reveal from './Reveal.astro';

// ⚠️ Placeholders NEUTRES uniquement — ce ne sont pas de vrais clients.
// TODO: remplacer par vrais logos clients avec accord (voir README).
const placeholders = ['◆ TERRA', '▲ LITTORAL', '● HORIZON', '■ BÂTIR', '⬢ MASCARIN'];
---

<section class="border-t border-white/5">
  <div class="mx-auto max-w-content px-5 py-14 sm:px-8">
    <Reveal>
      <div
        class="card flex flex-col items-center gap-7 px-6 py-8 sm:px-10 lg:flex-row lg:justify-between lg:gap-10"
      >
        <p class="flex-none text-center text-[15px] text-[#aab5b0] sm:text-[17px] lg:max-w-[220px] lg:text-left">
          Déjà adopté par des acteurs qui construisent La Réunion.
        </p>
        <span class="hidden h-10 w-px flex-none bg-white/[.07] lg:block" aria-hidden="true"></span>
        <!-- TODO: remplacer par vrais logos clients avec accord -->
        <ul class="flex flex-wrap items-center justify-center gap-x-7 gap-y-3 lg:flex-1 lg:justify-between" aria-label="Partenaires (exemples)">
          {
            placeholders.map((mark) => (
              <li class="select-none text-[16px] font-bold tracking-[.03em] text-[#7a857f] sm:text-[18px]">
                {mark}
              </li>
            ))
          }
        </ul>
      </div>
      <p class="mt-3 text-center text-[13px] text-muted lg:text-left">
        Logos illustratifs — remplacés par de vrais clients dès accord signé.
      </p>
    </Reveal>
  </div>
</section>
