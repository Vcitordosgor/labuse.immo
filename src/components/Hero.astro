---
import Radar from './Radar.astro';
import { CONTACT_ANCHOR } from '../consts';
---

<section id="top" class="relative overflow-hidden pt-[76px]">
  <div
    class="mx-auto grid max-w-content items-center gap-10 px-5 pb-8 pt-8 sm:px-8 lg:grid-cols-[46%_54%] lg:gap-6 lg:pb-12 lg:pt-12"
  >
    <!-- Colonne texte -->
    <div class="relative z-10">
      <div
        class="inline-flex items-center rounded-full border border-green/40 bg-green/5 px-4 py-2 font-mono text-[13px] font-semibold uppercase tracking-[.14em] text-green-soft sm:text-[15px]"
      >
        Radar foncier · La Réunion
      </div>

      <h1
        class="mt-7 max-w-[660px] text-[38px] font-semibold leading-[1.05] tracking-tightest sm:text-[52px] lg:text-[64px]"
      >
        Repérez les parcelles mutables <span class="text-green">avant les autres.</span>
      </h1>

      <p class="mt-6 max-w-[560px] text-[17px] leading-relaxed text-[#aab5b0] sm:text-[21px]">
        LA BUSE croise cadastre, PLU, PPR, faisabilité, prix et propriétaires sur les
        24 communes de La Réunion. Les parcelles réellement constructibles remontent
        d’elles-mêmes — avec le contact de leur propriétaire.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-5">
        <a
          href={CONTACT_ANCHOR}
          class="inline-flex h-[58px] items-center gap-3 rounded-2xl bg-green px-7 text-[17px] font-semibold text-[#04140f] shadow-glow transition-transform hover:-translate-y-0.5 sm:text-[19px]"
        >
          Demander une démo
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>
        <a
          href="#methode"
          class="inline-flex items-center gap-2.5 text-[17px] font-medium text-ink transition-opacity hover:opacity-80 sm:text-[18px]"
        >
          Voir comment ça marche
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 5v14M6 13l6 6 6-6"></path>
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <!-- Ordre DOM valide dt→dd ; la valeur s'affiche en premier via `order` -->
      <dl class="mt-12 grid grid-cols-1 gap-6 border-t border-white/[.07] pt-8 min-[420px]:grid-cols-3 min-[420px]:gap-4">
        <div class="flex flex-col">
          <dt class="order-2 mt-2 text-[14px] leading-tight text-muted">communes couvertes</dt>
          <dd class="order-1 whitespace-nowrap text-[clamp(24px,2.4vw,32px)] font-semibold leading-none tracking-tight text-green">24</dd>
        </div>
        <div class="flex flex-col min-[420px]:border-l min-[420px]:border-white/[.07] min-[420px]:pl-4">
          <dt class="order-2 mt-2 text-[14px] leading-tight text-muted">couches croisées</dt>
          <dd class="order-1 whitespace-nowrap text-[clamp(24px,2.4vw,32px)] font-semibold leading-none tracking-tight text-green">22</dd>
        </div>
        <div class="flex flex-col min-[420px]:border-l min-[420px]:border-white/[.07] min-[420px]:pl-4">
          <dt class="order-2 mt-2 text-[14px] leading-tight text-muted">du foncier passé au crible</dt>
          <dd class="order-1 whitespace-nowrap text-[clamp(24px,2.4vw,32px)] font-semibold leading-none tracking-tight text-green">100 %</dd>
        </div>
      </dl>
    </div>

    <!-- Colonne radar -->
    <div class="relative">
      <Radar>
        <!-- Carte de détection flottante (exemple illustratif, décoratif pour les lecteurs d'écran) -->
        <div class="detect-card hidden sm:block" aria-hidden="true">
          <div class="mb-3.5 flex items-center gap-2 text-[13px] font-medium text-[#d3ded8]">
            <i class="h-2 w-2 flex-none rounded-full bg-green-soft" style="box-shadow:0 0 10px rgba(124,243,207,.9)"></i>
            Parcelle · Saint-Paul
          </div>
          <div class="flex items-end justify-between">
            <div>
              <div class="text-[11px] uppercase tracking-wide text-muted">Score</div>
              <div class="text-[34px] font-bold leading-none text-green">
                87<span class="text-[15px] font-semibold text-[#8b978f]">/100</span>
              </div>
            </div>
          </div>
          <div class="my-3.5 h-px bg-coast/10"></div>
          <div class="flex items-center justify-between py-[5px] text-[13px]">
            <span class="text-[#b6c2bc]">Façade voirie</span>
            <span class="font-semibold text-green">18&nbsp;m</span>
          </div>
          <div class="flex items-center justify-between py-[5px] text-[13px]">
            <span class="text-[#b6c2bc]">Hauteur prospect</span>
            <span class="font-semibold">R+3</span>
          </div>
          <div class="flex items-center justify-between py-[5px] text-[13px]">
            <span class="text-[#b6c2bc]">Vue mer</span>
            <span class="font-semibold text-green">oui</span>
          </div>
        </div>
      </Radar>
    </div>
  </div>
</section>
