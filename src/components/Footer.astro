---
import { NAV, CONTACT_EMAIL } from '../consts';
import Logo from './Logo.astro';

const year = new Date().getFullYear();

// Liens légaux. (CGU à ajouter quand il y aura des conditions contractuelles.)
const legal = [
  { href: '/mentions-legales', label: 'Mentions légales' },
  { href: '/confidentialite', label: 'Politique de confidentialité' },
];
---

<footer class="border-t border-white/5 bg-bg">
  <div class="mx-auto max-w-content px-5 py-14 sm:px-8">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <!-- Marque -->
      <div>
        <a href="/" class="flex items-center gap-3 font-bold tracking-[.34em] text-ink" aria-label="LA BUSE — accueil">
          <Logo class="h-[14px] w-auto text-green" />
          <span class="text-[17px]">LA&nbsp;BUSE</span>
        </a>
        <p class="mt-5 max-w-[320px] text-[15px] leading-relaxed text-muted">
          Intelligence foncière pour promoteurs, bailleurs et investisseurs, à La Réunion.
          Le foncier constructible, révélé — parcelle par parcelle, propriétaire compris.
        </p>
      </div>

      <!-- Navigation -->
      <nav aria-label="Liens du site">
        <p class="font-mono text-[12px] font-semibold uppercase tracking-[.16em] text-muted" aria-hidden="true">Le site</p>
        <ul class="mt-4 flex flex-col gap-3">
          {
            NAV.map((item) => (
              <li>
                <a href={item.href} class="inline-block py-1 text-[15px] text-[#c3cdc7] transition-colors hover:text-green">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Contact + légal -->
      <div>
        <p class="font-mono text-[12px] font-semibold uppercase tracking-[.16em] text-muted" aria-hidden="true">Contact</p>
        <ul class="mt-4 flex flex-col gap-3">
          <li>
            <a href={`mailto:${CONTACT_EMAIL}`} class="text-[15px] text-[#c3cdc7] transition-colors hover:text-green">
              {CONTACT_EMAIL}
            </a>
          </li>
          <li class="text-[15px] text-muted">La Réunion (974)</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-white/5 pt-6 text-[13px] text-muted md:flex-row md:items-center md:justify-between">
      <p>© {year} LA BUSE · Fait à La Réunion.</p>
      <ul class="flex flex-wrap gap-x-6 gap-y-2">
        {
          legal.map((item) => (
            <li>
              <a href={item.href} class="inline-block py-1.5 transition-colors hover:text-green">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
