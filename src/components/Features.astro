---
import Reveal from './Reveal.astro';

const features = [
  {
    title: 'Détection multicritère',
    body: 'Filtres croisés : façade, voirie, unité foncière, division possible, dents creuses, zonage… Les parcelles à potentiel remontent seules, à l’échelle d’une commune entière.',
    icon: 'scan',
  },
  {
    title: 'Faisabilité pré-calculée',
    body: 'Constructibilité, gabarit, hauteur, nombre de logements, contraintes et ordre de prix : chaque parcelle est déjà évaluée. Vous arbitrez, vous ne calculez plus.',
    icon: 'gauge',
  },
  {
    title: 'PLU · PPR · SAR à jour',
    body: 'Règlement de zone, coefficients, hauteurs, aléas, servitudes : des règles intégrées et calibrées commune par commune, sur les 24 communes de l’île.',
    icon: 'layers',
  },
  {
    title: 'Propriétaires & pilotage',
    body: 'Qui possède la parcelle, comment le joindre, où en est la piste : de la détection au contact, tout se suit comme un CRM — plus jamais dans un tableur.',
    icon: 'contact',
  },
];

// Tracés SVG des icônes (stroke, viewBox 0 0 24 24).
const icons: Record<string, string> = {
  scan: '<path d="M4 8V6a2 2 0 0 1 2-2h2M16 4h2a2 2 0 0 1 2 2v2M20 16v2a2 2 0 0 1-2 2h-2M8 20H6a2 2 0 0 1-2-2v-2"/><circle cx="12" cy="12" r="3"/>',
  gauge: '<path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M13.4 10.6 19 5"/><path d="M6.34 17A8 8 0 1 1 17.66 17"/>',
  layers: '<path d="M12 2 3 7l9 5 9-5-9-5Z"/><path d="M3 12l9 5 9-5"/><path d="M3 17l9 5 9-5"/>',
  contact:
    '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
};
---

<section id="produit">
  <div class="mx-auto max-w-content px-5 py-20 sm:px-8 sm:py-24">
    <Reveal class="max-w-[720px]">
      <p class="eyebrow">Le produit</p>
      <h2 class="mt-6 text-[30px] font-semibold leading-[1.08] tracking-tightest sm:text-[42px]">
        Ce que fait <span class="text-green">LA BUSE.</span>
      </h2>
      <p class="mt-6 text-[17px] leading-relaxed text-[#aab5b0] sm:text-[19px]">
        Une chaîne complète, du signal foncier brut jusqu’au contact propriétaire —
        pensée pour le terrain réunionnais.
      </p>
    </Reveal>

    <div class="mt-14 grid gap-4 sm:grid-cols-2">
      {
        features.map((f, i) => (
          <Reveal delay={i * 90}>
            <article class="card card-interactive group h-full p-7">
              <span class="mb-6 grid h-14 w-14 place-items-center rounded-2xl border border-green/30 bg-green/5 text-green transition-colors group-hover:bg-green/10">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[f.icon]} />
              </span>
              <h3 class="text-[21px] font-semibold tracking-tight">{f.title}</h3>
              <p class="mt-3 text-[15.5px] leading-relaxed text-[#a7b2ac]">{f.body}</p>
            </article>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
