---
import { NAV, CONTACT_ANCHOR } from '../consts';
import Logo from './Logo.astro';
---

<header
  data-header
  class="fixed inset-x-0 top-0 z-50 transition-colors duration-300 data-[scrolled]:border-b data-[scrolled]:border-white/5 data-[scrolled]:bg-bg/80 data-[scrolled]:backdrop-blur-md"
>
  <div
    class="mx-auto flex h-[76px] max-w-content items-center justify-between px-5 transition-[height] duration-300 data-[scrolled]:h-[64px] sm:px-8"
    data-header
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 font-bold tracking-[.34em] text-ink" aria-label="LA BUSE — accueil">
      <Logo class="h-[15px] w-auto text-green drop-shadow-[0_0_10px_rgba(47,224,160,0.35)]" />
      <span class="text-[18px] sm:text-[20px]">LA&nbsp;BUSE</span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden items-center gap-8 lg:flex" aria-label="Navigation principale">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="text-[16px] font-medium text-muted transition-colors hover:text-ink"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={CONTACT_ANCHOR}
        class="rounded-xl border border-coast/30 px-5 py-2.5 text-[15px] font-medium text-ink transition-colors hover:border-green/60 hover:bg-green/5"
      >
        Demander une démo
      </a>
    </nav>

    <!-- Bouton menu mobile -->
    <button
      type="button"
      data-menu-btn
      class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 text-ink lg:hidden"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="menu-mobile"
    >
      <!-- Icône hamburger (menu fermé) -->
      <svg data-icon-open width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
      <!-- Icône croix (menu ouvert) — classe `hidden` (l'attribut hidden ne masque
           pas un <svg> : le preflight Tailwind force svg{display:block}) -->
      <svg data-icon-close class="hidden" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18"></path>
      </svg>
    </button>
  </div>

  <!-- Panneau mobile -->
  <div
    id="menu-mobile"
    data-menu-panel
    hidden
    class="border-t border-white/5 bg-bg px-5 pb-6 pt-2 lg:hidden"
  >
    <nav class="flex flex-col" aria-label="Navigation mobile">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            data-menu-link
            class="border-b border-white/5 py-3.5 text-[17px] font-medium text-ink"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={CONTACT_ANCHOR}
        data-menu-link
        class="mt-4 rounded-xl bg-green px-5 py-3.5 text-center text-[16px] font-semibold text-[#04140f]"
      >
        Demander une démo
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const btn = document.querySelector('[data-menu-btn]');
    const panel = document.querySelector('[data-menu-panel]');
    if (!btn || !panel) return;
    const iconOpen = btn.querySelector('[data-icon-open]');
    const iconClose = btn.querySelector('[data-icon-close]');
    const close = () => {
      panel.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Ouvrir le menu');
      if (iconOpen) iconOpen.classList.remove('hidden');
      if (iconClose) iconClose.classList.add('hidden');
      document.body.style.overflow = '';
    };
    const open = () => {
      panel.hidden = false;
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', 'Fermer le menu');
      if (iconOpen) iconOpen.classList.add('hidden');
      if (iconClose) iconClose.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    };
    btn.addEventListener('click', () => {
      panel.hidden ? open() : close();
    });
    panel.querySelectorAll('[data-menu-link]').forEach((link) => {
      link.addEventListener('click', close);
    });
    // Fermeture clavier (Échap, focus rendu au bouton) et clic hors panneau
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.hidden) {
        close();
        btn.focus();
      }
    });
    document.addEventListener('click', (e) => {
      if (!panel.hidden && !panel.contains(e.target) && !btn.contains(e.target)) close();
    });
    // Repli vers le desktop (≥ lg) avec le menu ouvert : on referme pour ne pas
    // laisser le scroll verrouillé sur un panneau devenu invisible.
    window.addEventListener('resize', () => {
      if (!panel.hidden && window.innerWidth >= 1024) close();
    });
  })();
</script>
