---
import Reveal from './Reveal.astro';

const steps = [
  {
    n: '01',
    title: 'Choisir une commune',
    body: 'Sélectionnez l’une des 24 communes, déjà calibrée : PLU, PPR et règles locales intégrés. Aucun paramétrage, aucune donnée à charger.',
  },
  {
    n: '02',
    title: 'Lire la carte de scores',
    body: 'La carte fait ressortir les parcelles les mieux notées. Filtrez par zone, hauteur, surface ou type de propriétaire, et comprenez chaque score en un clic.',
  },
  {
    n: '03',
    title: 'Passer à l’action',
    body: 'Ouvrez la fiche de faisabilité, identifiez le propriétaire, lancez le contact et suivez chaque piste jusqu’à la signature.',
  },
];
---

<section class="border-y border-white/5 bg-surface/30">
  <div class="mx-auto max-w-content px-5 py-20 sm:px-8 sm:py-24">
    <Reveal class="max-w-[720px]">
      <p class="eyebrow">Comment ça marche</p>
      <h2 class="mt-6 text-[30px] font-semibold leading-[1.08] tracking-tightest sm:text-[42px]">
        Trois étapes, <span class="text-green">du signal au contact.</span>
      </h2>
    </Reveal>

    <ol class="mt-14 grid gap-4 md:grid-cols-3">
      {
        steps.map((step, i) => (
          <Reveal as="li" delay={i * 110}>
            <div class="card h-full p-7">
              <div class="flex items-center gap-4">
                <span class="font-mono text-[38px] font-bold leading-none text-green">{step.n}</span>
                <span class="h-px flex-1 bg-gradient-to-r from-green/40 to-transparent" aria-hidden="true" />
              </div>
              <h3 class="mt-6 text-[21px] font-semibold tracking-tight">{step.title}</h3>
              <p class="mt-3 text-[15.5px] leading-relaxed text-[#a7b2ac]">{step.body}</p>
            </div>
          </Reveal>
        ))
      }
    </ol>
  </div>
</section>
