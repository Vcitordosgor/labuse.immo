---
import Reveal from './Reveal.astro';
import { DEMO_MAILTO } from '../consts';

// ─────────────────────────────────────────────────────────────────────────────
//  Aperçu produit : maquette illustrative de l'interface LA BUSE.
//  Carte cadastrale fabriquée (SVG) — parcelles colorées par score d'opportunité.
//  Génération DÉTERMINISTE (PRNG à graine fixe) → rendu stable à chaque build.
//  ⚠️ Données fictives, à vocation de démonstration.
// ─────────────────────────────────────────────────────────────────────────────
function mulberry32(a) {
  return function () {
    a |= 0;
    a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rng = mulberry32(0x1a2b3c4d);

const COLS = 9,
  ROWS = 6,
  W = 660,
  H = 440;
const cw = W / COLS,
  ch = H / ROWS;

// Treillis jitteré (les parcelles partagent leurs arêtes → look cadastre réel)
const pts: { x: number; y: number }[][] = [];
for (let r = 0; r <= ROWS; r++) {
  pts[r] = [];
  for (let c = 0; c <= COLS; c++) {
    const edgeX = c === 0 || c === COLS;
    const edgeY = r === 0 || r === ROWS;
    const jx = edgeX ? 0 : (rng() - 0.5) * cw * 0.55;
    const jy = edgeY ? 0 : (rng() - 0.5) * ch * 0.55;
    pts[r][c] = { x: +(c * cw + jx).toFixed(1), y: +(r * ch + jy).toFixed(1) };
  }
}

const selR = 2,
  selC = 4;
type Parcel = {
  path: string;
  score: number;
  cx: number;
  cy: number;
  selected: boolean;
};
const parcels: Parcel[] = [];
for (let r = 0; r < ROWS; r++) {
  for (let c = 0; c < COLS; c++) {
    const a = pts[r][c],
      b = pts[r][c + 1],
      d = pts[r + 1][c + 1],
      e = pts[r + 1][c];
    const gx = 1 - c / (COLS - 1);
    const gy = 1 - r / (ROWS - 1);
    let score = Math.round(28 + (gx * 0.55 + gy * 0.45) * 52 + (rng() - 0.5) * 46);
    score = Math.max(9, Math.min(96, score));
    const selected = r === selR && c === selC;
    if (selected) score = 87;
    parcels.push({
      path: `M${a.x} ${a.y}L${b.x} ${b.y}L${d.x} ${d.y}L${e.x} ${e.y}Z`,
      score,
      cx: +((a.x + d.x) / 2).toFixed(1),
      cy: +((a.y + d.y) / 2).toFixed(1),
      selected,
    });
  }
}

// Palette selon le score
function paint(s: number) {
  if (s >= 78) return { f: 'rgba(47,224,160,.5)', st: 'rgba(143,240,207,.85)' };
  if (s >= 60) return { f: 'rgba(47,224,160,.26)', st: 'rgba(47,224,160,.5)' };
  if (s >= 42) return { f: 'rgba(47,224,160,.1)', st: 'rgba(124,243,207,.22)' };
  return { f: 'rgba(120,140,133,.05)', st: 'rgba(120,140,133,.2)' };
}

// Voiries : lignes du treillis (r=3 horizontale, c=4 verticale)
const roadH = 'M' + pts[3].map((p) => `${p.x} ${p.y}`).join('L');
const roadV = 'M' + pts.map((row) => `${row[4].x} ${row[4].y}`).join('L');

// Quelques scores étiquetés (les meilleures opportunités, hors sélection)
const labels = parcels
  .filter((p) => !p.selected && p.score >= 80)
  .slice(0, 3);

const sel = parcels.find((p) => p.selected)!;

const metrics = [
  { k: 'Surface', v: '1 240 m²' },
  { k: 'Façade voirie', v: '18 m', hot: true },
  { k: 'Hauteur prospect', v: 'R+3' },
  { k: 'Vue mer', v: 'Oui', hot: true },
  { k: 'Zone PLU', v: 'UBa' },
  { k: 'Aléa PPR', v: 'Faible', hot: true },
];
const chips = [
  { label: 'Zone U', on: true },
  { label: 'Vue mer', on: true },
  { label: 'Surface > 800 m²', on: false },
];
---

<section class="relative overflow-hidden border-y border-white/5 bg-surface/30">
  <!-- glow d'arrière-plan -->
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-[420px] opacity-70"
    style="background:radial-gradient(circle at 50% 0%, rgba(47,224,160,.1), transparent 60%)"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-content px-5 py-20 sm:px-8 sm:py-24">
    <Reveal class="max-w-[720px]">
      <p class="eyebrow">Aperçu produit</p>
      <h2 class="mt-6 text-[30px] font-semibold leading-[1.08] tracking-tightest sm:text-[42px]">
        Une carte, et le foncier <span class="text-green">se révèle.</span>
      </h2>
      <p class="mt-6 text-[17px] leading-relaxed text-[#aab5b0] sm:text-[19px]">
        Chaque parcelle est notée et colorée par potentiel. Vous lisez une commune
        entière d’un coup d’œil, puis vous zoomez sur la pépite — score, contraintes et
        propriétaire en un clic.
      </p>
    </Reveal>

    <Reveal delay={120} class="mt-12">
      <!-- Fenêtre applicative (illustration) -->
      <figure
        class="overflow-hidden rounded-2xl border border-white/[.08] bg-[#0a1310] shadow-[0_40px_120px_-40px_rgba(0,0,0,.9)]"
        role="img"
        aria-label="Aperçu de l’interface LA BUSE : la carte des parcelles de Saint-Paul, colorées selon leur score d’opportunité, avec le détail d’une parcelle sélectionnée (score 87 sur 100)."
      >
        <div aria-hidden="true">
          <!-- Barre de titre -->
          <div class="flex items-center gap-4 border-b border-white/[.06] bg-white/[.02] px-4 py-3">
            <div class="flex gap-1.5">
              <span class="h-3 w-3 rounded-full bg-white/15"></span>
              <span class="h-3 w-3 rounded-full bg-white/15"></span>
              <span class="h-3 w-3 rounded-full bg-white/15"></span>
            </div>
            <div class="mx-auto flex items-center gap-2 rounded-lg border border-white/[.06] bg-black/30 px-3 py-1.5 font-mono text-[12px] text-muted">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              app.labuse.immo / saint-paul
            </div>
            <span class="hidden font-mono text-[11px] uppercase tracking-wider text-muted sm:block">MAJ · juil. 2026</span>
          </div>

          <!-- Barre d'outils / filtres -->
          <div class="flex flex-wrap items-center gap-2.5 border-b border-white/[.06] px-4 py-3">
            <span class="inline-flex items-center gap-2 rounded-lg border border-white/[.08] bg-white/[.03] px-3 py-1.5 text-[13px] font-medium text-ink">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11Z"/><circle cx="12" cy="10" r="2.2"/></svg>
              Saint-Paul
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </span>
            {
              chips.map((chip) => (
                <span
                  class:list={[
                    'inline-flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-[13px]',
                    chip.on
                      ? 'border-green/40 bg-green/10 text-green-soft'
                      : 'border-white/[.08] text-muted',
                  ]}
                >
                  {chip.on && (
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  )}
                  {chip.label}
                </span>
              ))
            }
            <span class="ml-auto hidden items-center gap-2 font-mono text-[11px] uppercase tracking-wider text-muted md:inline-flex">
              Score
              <span class="h-2.5 w-2.5 rounded-sm" style="background:rgba(47,224,160,.5)"></span>
              <span class="h-2.5 w-2.5 rounded-sm" style="background:rgba(47,224,160,.26)"></span>
              <span class="h-2.5 w-2.5 rounded-sm" style="background:rgba(120,140,133,.25)"></span>
            </span>
          </div>

          <!-- Corps : carte + panneau -->
          <div class="grid lg:grid-cols-[1.55fr_1fr]">
            <!-- Carte -->
            <div class="relative h-[300px] border-b border-white/[.06] sm:h-[360px] lg:h-auto lg:border-b-0 lg:border-r">
              <svg
                class="absolute inset-0 h-full w-full"
                viewBox="0 0 660 440"
                preserveAspectRatio="xMidYMid slice"
                xmlns="http://www.w3.org/2000/svg"
              >
                <rect width="660" height="440" fill="#07110d"/>
                {
                  parcels.map((p) => {
                    const c = paint(p.score);
                    return (
                      <path
                        d={p.path}
                        fill={p.selected ? 'rgba(47,224,160,.62)' : c.f}
                        stroke={p.selected ? '#baffe6' : c.st}
                        stroke-width={p.selected ? 2.4 : 1}
                        stroke-linejoin="round"
                      />
                    );
                  })
                }
                <!-- Voiries -->
                <path d={roadH} fill="none" stroke="#060a08" stroke-width="9" stroke-linecap="round" stroke-linejoin="round" opacity="0.85"/>
                <path d={roadV} fill="none" stroke="#060a08" stroke-width="9" stroke-linecap="round" stroke-linejoin="round" opacity="0.85"/>
                <path d={roadH} fill="none" stroke="rgba(124,243,207,.18)" stroke-width="1" stroke-dasharray="5 7"/>
                <path d={roadV} fill="none" stroke="rgba(124,243,207,.18)" stroke-width="1" stroke-dasharray="5 7"/>

                <!-- Étiquettes de score (opportunités) -->
                {
                  labels.map((p) => (
                    <g>
                      <rect x={p.cx - 15} y={p.cy - 10} width="30" height="19" rx="5" fill="#0a1310" stroke="rgba(47,224,160,.4)" stroke-width="1"/>
                      <text x={p.cx} y={p.cy + 4} text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="12" font-weight="700" fill="#8ff0cf">{p.score}</text>
                    </g>
                  ))
                }

                <!-- Parcelle sélectionnée : anneau pulsé + callout -->
                <circle class="pring" cx={sel.cx} cy={sel.cy} r="18"/>
                <circle class="pdot" cx={sel.cx} cy={sel.cy} r="4.5"/>
                <line x1={sel.cx} y1={sel.cy} x2={sel.cx + 60} y2={sel.cy - 46} stroke="rgba(143,240,207,.6)" stroke-width="1.2"/>
                <g transform={`translate(${sel.cx + 60}, ${sel.cy - 66})`}>
                  <rect width="128" height="40" rx="9" fill="#0b1613" stroke="rgba(143,240,207,.5)" stroke-width="1.2"/>
                  <text x="12" y="17" font-family="'JetBrains Mono', monospace" font-size="11" font-weight="700" fill="#d3ded8">AB-0421</text>
                  <text x="12" y="32" font-family="Inter, sans-serif" font-size="12" font-weight="700" fill="#2fe0a0">87<tspan fill="#8b978f">/100</tspan></text>
                  <text x="74" y="26" font-family="Inter, sans-serif" font-size="10" fill="#8ff0cf">détectée</text>
                </g>
              </svg>

              <!-- Contrôles carte (overlay) -->
              <div class="absolute bottom-3 right-3 flex flex-col overflow-hidden rounded-lg border border-white/[.1] bg-black/40 backdrop-blur-sm">
                <span class="grid h-8 w-8 place-items-center border-b border-white/[.1] text-ink">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
                <span class="grid h-8 w-8 place-items-center text-ink">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/></svg>
                </span>
              </div>
              <div class="absolute left-3 top-3 rounded-md border border-white/[.08] bg-black/40 px-2.5 py-1 font-mono text-[10px] uppercase tracking-wider text-muted backdrop-blur-sm">
                Cadastre · PLU · PPR
              </div>
            </div>

            <!-- Panneau de détail -->
            <aside class="flex flex-col gap-4 p-5 sm:p-6">
              <div class="flex items-center justify-between">
                <span class="font-mono text-[11px] uppercase tracking-[.14em] text-green-soft">Parcelle sélectionnée</span>
                <span class="rounded-md bg-green/10 px-2 py-0.5 font-mono text-[11px] font-semibold text-green">AB-0421</span>
              </div>

              <div class="flex items-end gap-3">
                <span class="text-[52px] font-bold leading-none text-green">87</span>
                <div class="pb-1.5">
                  <div class="text-[15px] font-semibold text-[#8b978f]">/100</div>
                  <div class="text-[12px] text-muted">top 6 % commune</div>
                </div>
                <div class="ml-auto pb-1 text-right">
                  <div class="text-[13px] font-medium text-ink">Score d’opportunité</div>
                  <div class="mt-1 h-1.5 w-24 overflow-hidden rounded-full bg-white/[.08]">
                    <span class="block h-full w-[87%] rounded-full bg-green"></span>
                  </div>
                </div>
              </div>

              <div class="hairline my-1"></div>

              <dl class="grid grid-cols-2 gap-x-4 gap-y-3.5">
                {
                  metrics.map((m) => (
                    <div>
                      <dt class="text-[12px] text-muted">{m.k}</dt>
                      <dd class:list={['mt-0.5 text-[15px] font-semibold', m.hot ? 'text-green' : 'text-ink']}>{m.v}</dd>
                    </div>
                  ))
                }
              </dl>

              <div class="rounded-xl border border-white/[.06] bg-white/[.02] px-4 py-3">
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-[#c3ceca]">Constructibilité estimée</span>
                  <span class="text-[15px] font-bold text-green">≈ 14 logts</span>
                </div>
              </div>

              <div class="mt-auto flex flex-col gap-2.5 pt-1">
                <span class="inline-flex items-center justify-center gap-2 rounded-xl bg-green px-4 py-3 text-[14px] font-semibold text-[#04140f]">
                  Fiche de pré-faisabilité
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </span>
                <span class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/[.12] px-4 py-3 text-[14px] font-medium text-ink">
                  Contacter le propriétaire
                </span>
              </div>
            </aside>
          </div>

          <!-- Barre de statut -->
          <div class="flex flex-col items-start gap-2 border-t border-white/[.06] px-4 py-2.5 text-[12px] text-muted sm:flex-row sm:items-center sm:justify-between">
            <div class="flex items-center gap-4">
              <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full" style="background:rgba(47,224,160,.7)"></span>Élevé</span>
              <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full" style="background:rgba(47,224,160,.32)"></span>Moyen</span>
              <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full" style="background:rgba(120,140,133,.4)"></span>Faible</span>
            </div>
            <span class="font-mono text-[11px]">3 214 parcelles · 214 opportunités</span>
          </div>
        </div>
      </figure>

      <p class="mt-4 text-center text-[12px] text-muted/70">
        Interface illustrative — données fictives à but de démonstration.
      </p>

      <div class="mt-8 text-center">
        <a
          href={DEMO_MAILTO}
          class="inline-flex h-[52px] items-center gap-2.5 rounded-2xl bg-green px-7 text-[16px] font-semibold text-[#04140f] shadow-glow transition-transform hover:-translate-y-0.5"
        >
          Voir la démo sur votre commune
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </Reveal>
  </div>
</section>
