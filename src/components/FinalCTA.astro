---
import Reveal from './Reveal.astro';
import { CONTACT_ANCHOR } from '../consts';
---

<section class="scroll-mt-24">
  <div class="mx-auto max-w-content px-5 py-20 sm:px-8 sm:py-24">
    <Reveal>
      <div
        class="relative overflow-hidden rounded-[32px] border border-green/25 bg-surface px-6 py-16 text-center sm:px-16 sm:py-20"
      >
        <!-- Glow discret d'arrière-plan -->
        <div
          class="pointer-events-none absolute inset-0 opacity-70"
          style="background:radial-gradient(circle at 50% 0%, rgba(47,224,160,.12), transparent 55%)"
          aria-hidden="true"
        >
        </div>

        <div class="relative">
          <div
            class="inline-flex items-center rounded-full border border-green/40 bg-green/5 px-4 py-2 font-mono text-[13px] font-semibold uppercase tracking-[.14em] text-green-soft"
          >
            Prêt à démarrer ?
          </div>
          <h2
            class="mx-auto mt-7 max-w-[720px] text-[32px] font-semibold leading-[1.08] tracking-tightest sm:text-[46px]"
          >
            Arrêtez de prospecter <span class="text-green">à l’aveugle.</span>
          </h2>
          <p class="mx-auto mt-6 max-w-[600px] text-[17px] leading-relaxed text-[#aab5b0] sm:text-[20px]">
            Dites-nous votre commune cible : on revient vers vous sous 24&nbsp;h avec une
            démonstration de LA BUSE sur votre terrain de jeu.
          </p>

          <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
            <a
              href={CONTACT_ANCHOR}
              class="inline-flex h-[58px] items-center gap-3 rounded-2xl bg-green px-8 text-[18px] font-semibold text-[#04140f] shadow-glow transition-transform hover:-translate-y-0.5"
            >
              Prendre contact
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </Reveal>
  </div>
</section>
