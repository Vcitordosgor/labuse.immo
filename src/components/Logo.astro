---
// Marque LA BUSE : buse stylisée en vol. La couleur suit `currentColor`
// (contrôlée via une classe text-*). Décoratif par défaut (le texte « LA BUSE »
// et l'aria-label du lien parent portent l'information).
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class:list={[className]}
  viewBox="0 0 240 82"
  fill="currentColor"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d="M2 15 C58 10 100 18 120 27 C140 18 182 10 238 15 C202 29 162 40 135 46 C127 49 122 53 120 60 C118 53 113 49 105 46 C78 40 38 29 2 15 Z"
  ></path>
</svg>
